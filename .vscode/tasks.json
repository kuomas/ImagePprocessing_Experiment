{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cmake",
			"label": "CMake Config Debug",
			"command": "configure",
			"targets": [
				"all"
			],
			"preset": "debug",
			"group": "none",
			"problemMatcher": [],
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": false
			},
			"hide": true
		},
		{
			"type": "cmake",
			"label": "CMake Build Debug",
			"command": "build",
			"targets": [
				"all"
			],
			"preset": "debug",
			"group": "build",
			"problemMatcher": [],
			"dependsOn": "CMake Config Debug",
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": false
			},
			"hide": true
		},
		{
			"label": "CMake Clean Build",
			"type": "shell",
			"command": "Remove-Item",
			"args": [
				"build/*",
				"-Recurse",
				"-Force",
				"-ErrorAction",
				"SilentlyContinue;",
				"Write-Output",
				"build目录已清空"
			],
			"group": "none",
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": false
			},
			"problemMatcher": []
		},
		{
			"label": "CMake Clean extlib",
			"type": "shell",
			"command": "Get-ChildItem",
			"args": [
				"-Path",
				"${workspaceFolder}/external",
				"-Directory",
				"|",
				"Remove-Item",
				"-Recurse",
				"-Force",
				"-ErrorAction",
				"SilentlyContinue;",
				"Write-Output",
				"external目录已清空"
			],
			"group": "none",
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": true,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": false
			},
			"problemMatcher": []
		}
	]
}