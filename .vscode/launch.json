{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DebugCpp",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/bin/${workspaceFolderBasename}.exe",  // 可执行文件路径
      "args": [],
      "stopAtEntry": true,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "CMake Build Debug"  // 启动前运行构建任务
    }
  ]
}